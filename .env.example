# Auth0 tenant domain without a scheme.
# Example: your-tenant.auth0.com
AUTH0_DOMAIN=your-tenant.auth0.com

# Machine-to-machine application credentials from Auth0.
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# This is the Auth0 API Identifier and becomes the JWT aud claim.
# It does not need to resolve on the network.
AUTH0_AUDIENCE=https://api.example.com/ords-api

# ORDS base URL without a trailing slash.
# Example: https://adb.example.com/ords
ORDS_BASE_URL=https://adb.example.com/ords

# ORDS-enabled schema path segment.
# If your schema is already ORDS-enabled, use the existing base path pattern
# from USER_ORDS_SCHEMAS rather than assuming "demo".
ORDS_SCHEMA=demo

# Module and template path relative to the schema path.
# With the defaults above, the full URL becomes:
# https://adb.example.com/ords/demo/oauth-demo/status
ORDS_PATH=oauth-demo/status

# Optional helper flag for scripts/get-token.sh.
# Set to true to print only the access token by default.
TOKEN_ONLY=false
